# Server
HOST=127.0.0.1
PORT=8000
APP_NAME=web-llm-adapter

# Browser / CDP
BROWSER_MODE=cdp
CDP_URL=http://127.0.0.1:9222
BROWSER_CHANNEL=msedge

# Paths (relative paths are resolved from the project root)
MASTER_PROFILE_DIR=.profiles/masters/doubao-edge
RUNTIME_PROFILE_DIR=.profiles/runtime/doubao-edge
ARTIFACT_DIR=.artifacts

# Runtime
TRACE_MODE=failure
MOCK_MODE=0
HEADLESS=0
STARTUP_BROWSER_CHECK=0
